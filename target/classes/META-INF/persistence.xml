<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence                         https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
  <persistence-unit name="appchatPU" transaction-type="JTA">
    <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>
    <jta-data-source>jdbc/appchatDS</jta-data-source>
    <class>com.appchat.model.Usuario</class>
    <class>com.appchat.model.Chat</class>
    <class>com.appchat.model.ChatDirecto</class>
    <class>com.appchat.model.Mensaje</class>
    <exclude-unlisted-classes>false</exclude-unlisted-classes>
    <properties>
      <property name="jakarta.persistence.schema-generation.database.action" value="none"/>
      <property name="hibernate.show_sql" value="true"/>
      <property name="hibernate.format_sql" value="true"/>
      <property name="eclipselink.target-database" value="PostgreSQL"/>
      <property name="eclipselink.logging.level" value="FINE"/>
    </properties>
  </persistence-unit>
</persistence>
