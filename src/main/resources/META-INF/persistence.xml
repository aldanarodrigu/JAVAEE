<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="chatPU" transaction-type="JTA">
        <class>com.chat.model.User</class>
        <class>com.chat.model.Message</class>
        <class>com.chat.model.Chat</class>
        <class>com.chat.model.ChatDirect</class>
        <class>com.chat.model.ChatGroup</class>
        <class>com.chat.model.Group</class>

        <properties>
            <!-- PostgreSQL DataSource
                 NOTE: Externalize credentials via environment variables or a secrets manager
                 before deploying to production. -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/chatdb"/>
            <property name="jakarta.persistence.jdbc.user" value="chatuser"/>
            <property name="jakarta.persistence.jdbc.password" value="chatpassword"/>

            <!-- Hibernate settings
                 NOTE: Change hbm2ddl.auto to 'validate' (or use Flyway/Liquibase) in production. -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.PostgreSQLDialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="false"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>
</persistence>
